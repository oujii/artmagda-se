# Resend (kontaktformulär)
RESEND_API_KEY="<your-resend-api-key>"
CONTACT_TO_EMAIL="info@example.com"
CONTACT_FROM_EMAIL="noreply@example.com"

# Stripe
STRIPE_SECRET_KEY="<your-stripe-secret-key>"
